OPENAI_API_KEY=

# Default model used when a request does not pass an explicit preset model.
# Prompt Lab experiments should normally set generator_model and judge_model.
LLM_MODEL=openai/gpt-5-mini

# Prompt Lab generator runs should keep cache disabled to expose variance.
LLM_CACHE=0
LLM_CACHE_DB_PATH=.cache/llm_cache.db

# Optional transport/debug settings.
LLM_TRANSPORT_RETRIES=1
LLM_LOG_PROGRESS=1
OPENAI_LOG=

