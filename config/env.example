OPENAI_API_KEY=

# Default fallback model used by the shared LLM layer when a request does not
# pass an explicit preset model.
#
# Prompt Lab normally passes explicit models from each experiment manifest:
#   experiment.json -> models.generator_model  (model being tested)
#   experiment.json -> models.judge_model      (judge/proposal/compare model)
LLM_MODEL=openai/gpt-5-mini

# Prompt Lab generator runs should keep cache disabled to expose variance.
LLM_CACHE=0
LLM_CACHE_DB_PATH=.cache/llm_cache.db

# Optional transport/debug settings.
LLM_TRANSPORT_RETRIES=1
LLM_LOG_PROGRESS=1
OPENAI_LOG=
